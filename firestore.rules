rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVE HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return false; } // No admin concepts required yet
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 512 && id.matches('^[a-zA-Z0-9_\\-\\.]+$'); }

    // --- VALIDATION BLUEPRINTS ---
    // User validation
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt', 'updatedAt']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 512 &&
             data.createdAt is number &&
             data.updatedAt is number &&
             (data.keys().hasAll(['displayName']) ? (data.displayName is string && data.displayName.size() <= 256) : true) &&
             (data.keys().hasAll(['avatarUrl']) ? (data.avatarUrl is string && data.avatarUrl.size() <= 2048) : true);
    }
    
    // Favorite validation
    function isValidFavorite(data) {
      return data.keys().hasAll(['userId', 'animeId', 'title', 'addedAt']) &&
             data.userId == request.auth.uid &&
             data.animeId is string && data.animeId.size() <= 512 &&
             data.title is string && data.title.size() <= 512 &&
             data.addedAt is number &&
             (data.keys().hasAll(['posterUrl']) ? (data.posterUrl is string && data.posterUrl.size() <= 2048) : true);
    }

    // WatchHistory validation
    function isValidHistory(data) {
      return data.keys().hasAll(['userId', 'animeId', 'episodeId', 'progressSeconds', 'lastWatchedAt']) &&
             data.userId == request.auth.uid &&
             data.animeId is string && data.animeId.size() <= 512 &&
             data.episodeId is string && data.episodeId.size() <= 512 &&
             data.progressSeconds is number &&
             data.lastWatchedAt is number &&
             (data.keys().hasAll(['durationSeconds']) ? (data.durationSeconds is number) : true);
    }

    // --- PATH RULES ---

    // USERS COLLECTION
    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
      allow list: if isSignedIn() && request.auth.uid == userId;
      
      allow create: if isSignedIn() && isValidId(userId) && 
                    userId == request.auth.uid && 
                    isValidUser(incoming());
                    
      allow update: if isSignedIn() && isValidId(userId) && 
                    userId == request.auth.uid && 
                    isValidUser(incoming()) && 
                    incoming().uid == existing().uid && 
                    incoming().createdAt == existing().createdAt;
                    
      allow delete: if false;

      // SUB-COLLECTION: FAVORITES
      match /favorites/{favoriteId} {
        allow get: if isSignedIn() && isValidId(userId) && isValidId(favoriteId) && userId == request.auth.uid;
        allow list: if isSignedIn() && isValidId(userId) && userId == request.auth.uid;
        
        allow create: if isSignedIn() && isValidId(userId) && isValidId(favoriteId) && 
                      userId == request.auth.uid && 
                      isValidFavorite(incoming()) &&
                      exists(/databases/$(database)/documents/users/$(userId));
                      
        allow update: if isSignedIn() && isValidId(userId) && isValidId(favoriteId) &&
                      userId == request.auth.uid && 
                      isValidFavorite(incoming()) &&
                      incoming().userId == existing().userId &&
                      incoming().animeId == existing().animeId &&
                      incoming().addedAt == existing().addedAt;
                      
        allow delete: if isSignedIn() && isValidId(userId) && isValidId(favoriteId) && 
                      userId == request.auth.uid;
      }

      // SUB-COLLECTION: HISTORY
      match /history/{historyId} {
        allow get: if isSignedIn() && isValidId(userId) && isValidId(historyId) && userId == request.auth.uid;
        allow list: if isSignedIn() && isValidId(userId) && userId == request.auth.uid;
        
        allow create: if isSignedIn() && isValidId(userId) && isValidId(historyId) && 
                      userId == request.auth.uid && 
                      isValidHistory(incoming());
                      
        allow update: if isSignedIn() && isValidId(userId) && isValidId(historyId) &&
                      userId == request.auth.uid && 
                      isValidHistory(incoming()) &&
                      incoming().userId == existing().userId &&
                      incoming().animeId == existing().animeId &&
                      incoming().episodeId == existing().episodeId;
                      
        allow delete: if isSignedIn() && isValidId(userId) && isValidId(historyId) && 
                      userId == request.auth.uid;
      }
    }
  }
}
